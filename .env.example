# Database Credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=appdb

# Neo4j Credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# Airflow Credentials
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_in_production
AIRFLOW_FERNET_KEY=generate_new_key_with_python_cryptography_fernet

# Kafka Configuration
KAFKA_BROKER_INTERNAL=kafka:29092
KAFKA_BROKER_EXTERNAL=localhost:9092
